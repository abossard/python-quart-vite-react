"""
Ollama Structured Output Parser

Robust parser and validator for LLM-generated JSON output.
Handles various failure modes with automatic repair strategies.

Following "Grokking Simplicity":
- Pure calculations: JSON parsing, validation, schema checking
- Actions: Logging, calling Ollama
- Clear error hierarchy

Key features:
- Multiple parsing strategies (tool_call, JSON fence, raw JSON)
- Automatic retry with repair prompts
- Schema validation with jsonschema
- Detailed error messages for debugging

Example usage:
    parser = StructuredOutputParser(schema=KBA_OUTPUT_SCHEMA)
    result = await parser.parse_with_retry(
        ollama_response=response,
        retry_fn=lambda prompt: ollama.chat([{"role": "user", "content": prompt}]),
        original_prompt=prompt
    )
"""

import json
import logging
import re
from typing import Any, Callable, Optional

import jsonschema
from jsonschema import ValidationError

logger = logging.getLogger(__name__)


class OutputParseError(Exception):
    """Base exception for parsing errors"""
    pass


class NoJSONFoundError(OutputParseError):
    """No JSON could be extracted from response"""
    pass


class InvalidJSONError(OutputParseError):
    """JSON syntax is invalid"""
    pass


class SchemaValidationError(OutputParseError):
    """JSON doesn't match required schema"""
    def __init__(self, message: str, validation_errors: list[str]):
        super().__init__(message)
        self.validation_errors = validation_errors


class StructuredOutputParser:
    """
    Parser for extracting and validating structured JSON from LLM output
    """
    
    def __init__(self, schema: dict):
        """
        Initialize parser with JSON Schema
        
        Args:
            schema: JSON Schema (Draft 7) for validation
        """
        self.schema = schema
        
        # Pre-compile schema for faster validation
        try:
            jsonschema.Draft7Validator.check_schema(schema)
            self.validator = jsonschema.Draft7Validator(schema)
        except jsonschema.SchemaError as e:
            logger.error(f"Invalid JSON Schema: {e}")
            raise ValueError(f"Invalid schema: {e}")
    
    def parse(self, response: dict | str) -> dict:
        """
        Parse structured output from Ollama response
        
        Tries multiple extraction strategies in order:
        1. Tool call / function call (if available)
        2. JSON code block (```json ... ```)
        3. Raw JSON object extraction
        4. Full response as JSON
        
        Args:
            response: Ollama response (dict or string)
            
        Returns:
            Parsed and validated JSON dict
            
        Raises:
            NoJSONFoundError: If no JSON could be extracted
            InvalidJSONError: If JSON syntax is invalid
            SchemaValidationError: If JSON doesn't match schema
        """
        # Strategy 1: Tool call (future-proofing for Ollama tool support)
        if isinstance(response, dict):
            # Check for tool_call or function_call
            message = response.get("message", {})
            
            if "tool_calls" in message:
                tool_call = message["tool_calls"][0]
                json_str = tool_call.get("function", {}).get("arguments", "")
                if json_str:
                    logger.debug("Extracted JSON from tool_calls")
                    return self._parse_and_validate(json_str, source="tool_call")
            
            # Extract content string
            response_text = message.get("content", "")
        else:
            response_text = response
        
        # Strategy 2: JSON code block
        json_match = re.search(
            r'```(?:json)?\s*\n(.*?)\n```',
            response_text,
            re.DOTALL | re.IGNORECASE
        )
        
        if json_match:
            json_str = json_match.group(1).strip()
            logger.debug(f"Extracted JSON from code block ({len(json_str)} chars)")
            return self._parse_and_validate(json_str, source="code_block")
        
        # Strategy 3: Raw JSON object
        json_match = re.search(r'\{[^{}]*(?:\{[^{}]*\}[^{}]*)*\}', response_text, re.DOTALL)
        
        if json_match:
            json_str = json_match.group(0).strip()
            logger.debug(f"Extracted JSON object ({len(json_str)} chars)")
            return self._parse_and_validate(json_str, source="json_extraction")
        
        # Strategy 4: Full response
        if response_text.strip().startswith('{'):
            logger.debug("Attempting to parse full response as JSON")
            return self._parse_and_validate(response_text.strip(), source="full_response")
        
        # No JSON found
        logger.error(
            "No JSON found in response",
            extra={"response_preview": response_text[:200]}
        )
        raise NoJSONFoundError(
            f"Could not extract JSON from response. "
            f"Preview: {response_text[:100]}..."
        )
    
    def _parse_and_validate(self, json_str: str, source: str) -> dict:
        """
        Parse JSON string and validate against schema
        
        Args:
            json_str: JSON string to parse
            source: Source description for logging
            
        Returns:
            Validated dict
            
        Raises:
            InvalidJSONError: If JSON parsing fails
            SchemaValidationError: If validation fails
        """
        # Parse JSON
        try:
            data = json.loads(json_str)
        except json.JSONDecodeError as e:
            logger.warning(
                f"JSON decode error from {source}",
                extra={"error": str(e), "json_preview": json_str[:200]}
            )
            raise InvalidJSONError(f"Invalid JSON syntax: {e.msg} at position {e.pos}")
        
        # Validate schema
        validation_errors = list(self.validator.iter_errors(data))
        
        if validation_errors:
            error_messages = []
            for error in validation_errors[:5]:  # Limit to first 5 errors
                path = ".".join(str(p) for p in error.absolute_path) or "root"
                error_messages.append(f"{path}: {error.message}")
            
            logger.warning(
                f"Schema validation failed ({len(validation_errors)} errors)",
                extra={"errors": error_messages}
            )
            
            raise SchemaValidationError(
                f"Schema validation failed: {len(validation_errors)} errors",
                error_messages
            )
        
        logger.info(f"Successfully parsed and validated JSON from {source}")
        return data
    
    async def parse_with_retry(
        self,
        ollama_response: dict | str,
        retry_fn: Callable[[str], Any],
        original_prompt: str,
        max_retries: int = 1
    ) -> dict:
        """
        Parse with automatic retry on validation errors
        
        If parsing/validation fails, will retry with a repair prompt that includes:
        - The original prompt
        - The failed JSON output
        - Specific validation errors
        - The required schema
        
        Args:
            ollama_response: Initial Ollama response
            retry_fn: Async function to call Ollama again (takes prompt, returns response)
            original_prompt: Original user prompt
            max_retries: Maximum repair attempts (default: 1)
            
        Returns:
            Validated dict
            
        Raises:
            OutputParseError: If parsing fails after all retries
        """
        # Extract response text early for error handling
        if isinstance(ollama_response, dict):
            response_text = ollama_response.get("message", {}).get("content", "")
        else:
            response_text = ollama_response
        
        # Attempt 1: Parse initial response
        last_error = None
        try:
            return self.parse(ollama_response)
        except OutputParseError as e:
            last_error = e
            logger.info(f"Initial parse failed: {e}. Attempting repair (max {max_retries} retries)")
        
        # Retry with repair prompt
        for attempt in range(1, max_retries + 1):
            try:
                repair_prompt = self._build_repair_prompt(
                    original_prompt=original_prompt,
                    failed_output=response_text,
                    error=str(last_error)
                )
                
                logger.debug(f"Retry attempt {attempt}/{max_retries}")
                
                # Call LLM again
                retry_response = await retry_fn(repair_prompt)
                
                # Extract response text
                if isinstance(retry_response, dict):
                    response_text = retry_response.get("message", {}).get("content", "")
                else:
                    response_text = retry_response
                
                # Try to parse
                result = self.parse(retry_response)
                
                logger.info(f"Repair successful on attempt {attempt}/{max_retries}")
                return result
                
            except OutputParseError as retry_error:
                logger.warning(f"Retry {attempt} failed: {retry_error}")
                last_error = retry_error  # Update error for next iteration or final raise
        
        # All retries failed
        logger.error(
            f"All {max_retries} repair attempts failed",
            extra={"final_error": str(last_error)}
        )
        raise last_error
    
    def _build_repair_prompt(
        self,
        original_prompt: str,
        failed_output: str,
        error: str
    ) -> str:
        """
        Build repair prompt with error feedback
        
        Args:
            original_prompt: Original user prompt
            failed_output: The LLM's failed output
            error: Error message
            
        Returns:
            Repair prompt string
        """
        required_fields = self.schema.get("required", [])
        
        prompt = f"""Your previous response had formatting errors. Please fix and respond with VALID JSON ONLY.

ERROR: {error}

ORIGINAL REQUEST:
{original_prompt}

YOUR FAILED OUTPUT:
{failed_output[:1000]}

REQUIREMENTS:
1. Output MUST be valid JSON (use double quotes, escape special chars)
2. Output MUST be wrapped in ```json code block
3. Required fields: {', '.join(required_fields)}
4. Follow the exact schema structure

CORRECT FORMAT EXAMPLE:
```json
{{
  "title": "Example Title Here",
  "symptoms": ["symptom 1", "symptom 2"],
  "resolution_steps": ["step 1", "step 2"],
  "tags": ["tag1", "tag2", "tag3"]
}}
```

NOW OUTPUT THE CORRECTED JSON:"""
        
        return prompt


def create_repair_prompt_simple(original_prompt: str, error: str) -> str:
    """
    Create a simple repair prompt without the failed output
    
    Used when failed output is too long or contains invalid characters
    
    Args:
        original_prompt: Original prompt
        error: Error message
        
    Returns:
        Simple repair prompt
    """
    return f"""Your previous response was invalid. Please try again.

ERROR: {error}

ORIGINAL REQUEST:
{original_prompt}

IMPORTANT:
- Output MUST be valid JSON
- Wrap JSON in ```json code block
- Use double quotes for strings
- Escape special characters

Please provide the corrected output now:"""
